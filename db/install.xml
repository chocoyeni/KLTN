<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/ednet_import/db" VERSION="2026050604" COMMENT="EdNet import tables">

    <TABLES>

        <TABLE NAME="local_ednet_interactions" COMMENT="Store EdNet interactions">

            <FIELDS>

                <FIELD NAME="id"
                       TYPE="int"
                       LENGTH="10"
                       NOTNULL="true"
                       SEQUENCE="true"
                       COMMENT="Primary key"/>

                <FIELD NAME="user_id"
                       TYPE="char"
                       LENGTH="50"
                       NOTNULL="true"
                       COMMENT="User ID"/>

                <FIELD NAME="question_id"
                       TYPE="char"
                       LENGTH="50"
                       NOTNULL="true"
                       COMMENT="Question ID"/>

                <FIELD NAME="user_answer"
                       TYPE="char"
                       LENGTH="10"
                       NOTNULL="false"
                       COMMENT="User answer"/>

                <FIELD NAME="correct_answer"
                       TYPE="char"
                       LENGTH="10"
                       NOTNULL="false"
                       COMMENT="Correct answer"/>

                <FIELD NAME="elapsed_time"
                       TYPE="int"
                       LENGTH="10"
                       NOTNULL="false"
                       COMMENT="Elapsed time ms"/>

                <FIELD NAME="timestamp"
                       TYPE="char"
                       LENGTH="20"
                       NOTNULL="false"
                       COMMENT="Timestamp"/>

            </FIELDS>

            <KEYS>
                <KEY NAME="primary"
                     TYPE="primary"
                     FIELDS="id"/>
            </KEYS>

        </TABLE>

    </TABLES>

</XMLDB>